        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Ports suspects bloqués (24h)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "loki", "uid": "${loki_uid}" },
        "expr": "sum(count_over_time({job=\"pfsense\", type=\"firewall\", action=\"block\", dst_port=~\"22|23|3389|445|1433|3306\"}[24h]))",
        "legendFormat": "suspects",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_uid}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
