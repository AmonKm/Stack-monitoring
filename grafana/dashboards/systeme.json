      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${prometheus_uid}" },
        "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
        "legendFormat": "{{hostname}} — {{device}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_uid}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
