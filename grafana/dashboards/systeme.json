      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${prometheus_uid}" },
        "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[5m])",
        "legendFormat": "{{hostname}} — {{device}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_uid}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 3600 }
            ]
          },
          "unit": "s",
          "custom": { "displayMode": "color-background", "align": "center" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "instance" }, "properties": [{ "id": "custom.width", "value": 200 }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.width", "value": 150 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "id": 8,
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": false, "displayName": "Value" }]
      },
      "title": "⏱️ Uptime des VMs",
      "type": "table",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${prometheus_uid}" },
        "expr": "time() - node_boot_time_seconds",
        "legendFormat": "{{hostname}}",
        "refId": "A",
        "instant": true
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_uid}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "id": 9,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "title": "État des VMs",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${prometheus_uid}" },
        "expr": "up{job=~\"node|monitoring\"}",
        "legendFormat": "{{hostname}}",
        "refId": "A"
      }]
    }
