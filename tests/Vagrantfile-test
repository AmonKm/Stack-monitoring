Vagrant.configure("2") do |config|

  config.vm.define "monitoring" do |m|
    m.vm.box = "debian/bookworm64"
    m.vm.hostname = "monitoring"
    m.vm.network "private_network", ip: "10.0.0.50"
    m.vm.provider "virtualbox" do |vb|
      vb.memory = "2048"
      vb.cpus = 2
    end
    m.vm.provision "shell", path: "../provision.sh"
  end

  config.vm.define "si-client" do |s|
    s.vm.box = "debian/bookworm64"
    s.vm.hostname = "si-client"
    s.vm.network "private_network", ip: "10.0.0.10"
    s.vm.provider "virtualbox" do |vb|
      vb.memory = "512"
      vb.cpus = 1
    end
  end

end
